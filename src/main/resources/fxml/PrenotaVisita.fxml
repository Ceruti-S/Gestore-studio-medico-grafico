<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="main-home-container"
      stylesheets="@../css/FunzionalitàSegretario.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studioMedico.GCM.frontend.controller.PrenotaVisitaController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="label-titolo" text="Prenotazione Visita"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <GridPane hgap="20.0" vgap="15.0">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="150.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
        </columnConstraints>

        <children>
            <Label styleClass="label-campo" text="CUI Paziente:" GridPane.rowIndex="0" />
            <TextField fx:id="cuiPaziente" promptText="Inserisci CUI Paziente" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="label-campo" text="CUI Medico:" GridPane.rowIndex="1" />
            <TextField fx:id="cuiMedico" promptText="Inserisci CUI Medico" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="label-campo" text="Data Visita:" GridPane.rowIndex="2" />
            <DatePicker fx:id="dataVisita" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label styleClass="label-campo" text="Ora Visita (HH:mm):" GridPane.rowIndex="3" />
            <TextField fx:id="oraVisita" promptText="es. 10:30" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label styleClass="label-campo" text="Motivo:" GridPane.rowIndex="4" />
            <TextField fx:id="motivo" promptText="es. Controllo" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label styleClass="label-campo" text="Note:" GridPane.rowIndex="5" />
            <TextArea fx:id="note" prefHeight="100.0" promptText="Eventuali note aggiuntive..." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </children>

        <rowConstraints>
            <RowConstraints minHeight="30.0" />
            <RowConstraints minHeight="30.0" />
            <RowConstraints minHeight="30.0" />
            <RowConstraints minHeight="30.0" />
            <RowConstraints minHeight="30.0" />
            <RowConstraints minHeight="100.0" />
        </rowConstraints>
    </GridPane>

    <Button styleClass="action-button" text="CONFERMA PRENOTAZIONE"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" onAction="#prenotaVisita"/>

</VBox>