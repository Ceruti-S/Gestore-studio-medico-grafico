<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="main-home-container"
      stylesheets="@../css/FunzionalitàSegretario.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studioMedico.GCM.frontend.controller.PrenotaEsameController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <children>
        <Label styleClass="label-titolo" text="Prenotazione Esame Diagnostico"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

        <VBox maxWidth="600.0" spacing="20.0">
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-campo" text="CUI Paziente:" />
                        <TextField fx:id="cuiPazienteEsame" promptText="Inserisci CUI del paziente (es. P1)..." />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-campo" text="CUI Medico Prescrivente:" />
                        <TextField fx:id="cuiMedicoEsame" promptText="Inserisci CUI medico..." />
                    </children>
                </VBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="label-campo" text="Data Esame:" />
                                <DatePicker fx:id="dataEsame" maxWidth="Infinity" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="label-campo" text="Ora (HH:mm):" />
                                <TextField fx:id="oraEsame" prefWidth="100.0" promptText="10:30" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-campo" text="Tipo di Esame / Prestazione:" />
                        <TextField fx:id="nomeEsame" promptText="es. Radiografia, Analisi del sangue, ECG..." />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-campo" text="Note / Requisiti (es. a digiuno):" />
                        <TextArea fx:id="noteEsame" prefHeight="100.0" promptText="Note opzionali per il paziente o il tecnico..." wrapText="true" />
                    </children>
                </VBox>

                <Region prefHeight="10.0" />

                <Button maxWidth="Infinity" styleClass="action-button" text="CONFERMA E PRENOTA ESAME"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-cursor: hand;" onAction="#prenotaEsame"/>
            </children>
        </VBox>
    </children>
</VBox>