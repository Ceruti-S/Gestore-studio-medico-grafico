<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="main-home-container"
      stylesheets="@../css/FunzionalitàSegretario.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
        <children>
            <Label text="Modifica Paziente" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="cuiRicerca" prefWidth="200.0" promptText="Inserisci CUI Paziente..." style="-fx-background-radius: 15;" />
            <Button style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="CARICA DATI" />
        </children>
    </HBox>

    <HBox spacing="40.0">
        <children>
            <VBox spacing="15.0" prefWidth="300.0">
                <children>
                    <Label text="Dati Identificativi" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                    <TextField fx:id="nome" promptText="Nome" />
                    <TextField fx:id="cognome" promptText="Cognome" />
                    <TextField fx:id="telefono" promptText="Recapito Telefonico" />
                </children>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Note Mediche / Storico" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                    <TextArea fx:id="note" prefHeight="150.0" promptText="Inserisci qui aggiornamenti sulle condizioni o note personali..." wrapText="true" />
                </children>
            </VBox>
        </children>
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <Button maxWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-cursor: hand;"
            text="SALVA MODIFICHE ANAGRAFICHE" />

</VBox>