<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20.0" styleClass="main-home-container"
      stylesheets="@../css/ITSupport.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studioMedico.GCM.frontend.controller.AggiungiMedicoController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="label-titolo" text="Registrazione Nuovo Medico"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <HBox spacing="40.0" alignment="CENTER">
        <children>
            <VBox prefWidth="400.0" spacing="15.0">
                <children>
                    <Label text="Dati Profilo Medico" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />

                    <TextField fx:id="nome" promptText="Nome" />
                    <TextField fx:id="cognome" promptText="Cognome" />
                    <DatePicker fx:id="dataNascita" maxWidth="Infinity" promptText="Data di nascita" />
                    <TextField fx:id="codiceFiscale" promptText="Codice Fiscale" />
                    <TextField fx:id="specializzazione" promptText="Specializzazione"/>
                </children>
            </VBox>
        </children>
    </HBox>

    <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
        <Button maxWidth="Infinity" styleClass="btn-conferma" text="REGISTRA MEDICO"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-cursor: hand; -fx-background-radius: 5;"
                onAction="#gestisciAggiunta"/>
    </VBox>

</VBox>