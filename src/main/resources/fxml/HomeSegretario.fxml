<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" styleClass="main-container" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studioMedico.GCM.frontend.controller.HomeSegretarioController">

   <top>
      <VBox style="-fx-background-color: white;">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0">
               <padding>
                  <Insets left="25.0" right="25.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <TextField prefWidth="250.0" promptText="Cerca paziente (CUI o Cognome)..." style="-fx-background-radius: 20;" fx:id="txtRicercaRapida"/>
                     <Button styleClass="login-button" text="Cerca" onAction="#gestisciRicerca"/>
                  </HBox>

                  <Region HBox.hgrow="ALWAYS" />

                  <VBox alignment="CENTER" spacing="2.0">
                     <Label fx:id="lblNomeUtente" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Utente: Segretario" />
                     <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Accesso Standard" />
                  </VBox>

                  <Region HBox.hgrow="ALWAYS" />

                  <Button styleClass="logout-button" text="logout"
                          style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5;" onAction="#gestisciLogout"/>
               </children>
            </HBox>

            <Region prefHeight="3.0" style="-fx-background-color: #34495e;" />
         </children>
      </VBox>
   </top>

   <left>
      <HBox>
         <children>
            <VBox prefWidth="260.0" spacing="15.0" style="-fx-background-color: #f0f4f7;">
               <padding>
                  <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
               </padding>
               <children>
                  <Label text="PRENOTAZIONI" style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-font-weight: bold;">
                     <VBox.margin><Insets left="10.0" /></VBox.margin>
                  </Label>

                  <Button maxWidth="Infinity" styleClass="menu-button" text="• Fissa Visita" onAction="#gestisciAperturaPrenotaVisita"/>
                  <Button maxWidth="Infinity" styleClass="menu-button" text="• Fissa Esame" onAction="#gestisciAperturaPrenotaEsame"/>
                  <Region prefHeight="10.0" />

                  <Label text="ANAGRAFICA" style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-font-weight: bold;">
                     <VBox.margin><Insets left="10.0" /></VBox.margin>
                  </Label>

                  <Button maxWidth="Infinity" styleClass="menu-button" text="• Aggiungi Nuovo Paziente" onAction="#gestisciAperturaAggiungiPaziente"/>
                  <Button maxWidth="Infinity" styleClass="menu-button" text="• Modifica Info Paziente" onAction="#gestisciAperturaModificaPaziente"/>

                  <Region prefHeight="10.0" />

                  <Label text="STRUMENTI" style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-font-weight: bold;">
                     <VBox.margin><Insets left="10.0" /></VBox.margin>
                  </Label>
                  <Button maxWidth="Infinity" styleClass="menu-button" text="• Lista pazienti" onAction="#gestisciAperturaListaPazienti"/>

               </children>
            </VBox>

            <Region prefWidth="3.0" style="-fx-background-color: #34495e;" />
         </children>
      </HBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: #ffffff;">
         <children>
            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Label styleClass="title-label" text="GCM Studio" style="-fx-font-size: 32px; -fx-text-fill: #ecf0f1;" />
                  <Label text="Benvenuto nella console di Segreteria" style="-fx-text-fill: #bdc3c7;" />
                  <Label maxWidth="400.0" text="Usa il menu a sinistra per gestire le prenotazioni con ricetta medica o i pazienti liberi."
                         textAlignment="CENTER" wrapText="true" style="-fx-text-fill: #95a5a6; -fx-font-style: italic;" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>