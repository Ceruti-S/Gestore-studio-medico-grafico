<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.studioMedico.GCM.frontend.LoginController"
      prefWidth="400" prefHeight="300" styleClass="main-container">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Accesso Studio Medico GCM" styleClass="title-label"/>

    <GridPane vgap="10" hgap="10">
        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtUsername" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="es. M1_rossi"/>

        <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <PasswordField fx:id="txtPassword" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <CheckBox fx:id="chkRecovery" text="Accesso in Recovery Mode"/>

    <Button text="ACCEDI" onAction="#gestisciLogin" maxWidth="Infinity" styleClass="login-button"/>

    <Label fx:id="lblStatus" styleClass="status-label"/>
</VBox>